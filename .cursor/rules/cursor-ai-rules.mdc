## Code Templates

### Gateway Controller
```typescript
@Controller('auth')
export class AuthController {
  constructor(
    @Inject(AUTH_SERVICE) private readonly authClient: ClientProxy,
  ) {}

  @Public()
  @Post('login')
  login(@Body() dto: LoginDto): Promise<AuthResponseDto> {
    return firstValueFrom(this.authClient.send(AUTH_PATTERNS.LOGIN, dto));
  }

  @Get('me')
  getMe(@User() user: AuthorizedUser): Promise<CurrentUserResponseDto> {
    return firstValueFrom(
      this.authClient.send(AUTH_PATTERNS.ME, { context: user }),
    );
  }
}
```

### Auth-service Controller
```typescript
@Controller()
export class AuthController {
  constructor(private readonly authService: AuthService) {}

  @MessagePattern(AUTH_PATTERNS.LOGIN)
  login(@Payload() dto: LoginDto): Promise<AuthResponseDto> {
    return this.authService.login(dto);
  }

  @MessagePattern(AUTH_PATTERNS.ME)
  getMe(@Payload() { context }: { context: AuthContext }): Promise<CurrentUserResponseDto> {
    return this.authService.getMe(context.accountId);
  }
}
```

### Service
```typescript
@Injectable()
export class AuthService {
  constructor(private readonly repository: AuthRepository) {}

  async login(dto: LoginDto): Promise<AuthResponseDto> {
    const account = await this.repository.findByEmail(dto.email);
    if (!account) throw new UnauthorizedException('Invalid credentials');
    const valid = await bcrypt.compare(dto.password, account.passwordHash);
    if (!valid) throw new UnauthorizedException('Invalid credentials');
    return this.buildAuthResponse(account);
  }
}
```

### Repository
```typescript
@Injectable()
export class AuthRepository {
  constructor(private readonly prisma: PrismaService) {}

  async findByEmail(email: string): Promise<Account | null> {
    return this.prisma.account.findUnique({
      where: { email },
      include: { user: { include: { role: true } } },
    });
  }
}
```

